# Required: Postgres connection URL (same as POLYQUEUE_DB_URL used by the worker)
POLYQUEUE_DB_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Optional: table configuration (must match worker config)
POLYQUEUE_TABLE_SCHEMA=public
POLYQUEUE_TABLE_NAME=polyqueue_jobs
POLYQUEUE_WORKERS_TABLE_NAME=polyqueue_workers

# Optional: threshold overrides (seconds)
POLYQUEUE_STALE_PROGRESS_THRESHOLD=120
POLYQUEUE_WORKER_STALE_THRESHOLD=60

# Optional: dashboard server port (default: 3030)
PORT=3030
